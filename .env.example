# MongoDB
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=bmtc

# Redis (optional — app works without it)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Application
DEBUG=false
API_PREFIX=/api
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60

# Simulation
SIMULATION_INTERVAL_SECONDS=3.0
SIMULATION_STEPS_BETWEEN_STOPS=10
